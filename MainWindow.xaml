                        <TranslateTransform x:Name="BootTitleTr" Y="12"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="28" ShadowDepth="0" Opacity="0.55"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="BootSubtitle" Text="R E M A K E   L A U N C H E R" FontFamily="Consolas, Courier New" FontSize="12"
