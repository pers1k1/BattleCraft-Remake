<Window x:Class="CustomLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:core="clr-namespace:CustomLauncher.Core"
        x:Name="MainWnd"
        Title="BattleCraft Remake Launcher" 
        Height="650" Width="1100"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        FontFamily="Bahnschrift, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"  
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="PrimaryColor">#0D0D1E</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>

        <Color x:Key="AccentColor">#BB86FC</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>

        <sys:Double x:Key="BloomBlurRadius">15</sys:Double>
        <sys:Double x:Key="BloomOpacity">0.6</sys:Double>
        <sys:Double x:Key="TitleBloomBlurRadius">30</sys:Double>
        <sys:Double x:Key="TitleBloomOpacity">0.4</sys:Double>


        <Style x:Key="SystemButton" TargetType="Button">
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource SystemButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle" CornerRadius="4" Height="{TemplateBinding Height}" SnapsToDevicePixels="True" Background="{DynamicResource AccentBrush}" Opacity="0.6"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <EventSetter Event="PreviewMouseMove" Handler="Btn_MouseTrack"/>
            <EventSetter Event="MouseLeave" Handler="Btn_MouseReset"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="GlowBorder" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Opacity="1">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="GlowEffect" 
                                                      Color="{DynamicResource AccentColor}" 
                                                      BlurRadius="30" 
                                                      ShadowDepth="0" 
                                                      Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="BorderElement" 
                                    Background="Transparent" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="GlowContent" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform x:Name="BtnTr" X="0" Y="0"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.95" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.95" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Bd" Width="20" Height="20" CornerRadius="5" BorderBrush="#44FFFFFF" BorderThickness="1.5" Background="#10FFFFFF">
                                <Border x:Name="Ck" CornerRadius="3" Margin="3" Background="{DynamicResource AccentBrush}" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><ScaleTransform x:Name="CkScale" ScaleX="0" ScaleY="0"/></Border.RenderTransform>
                                </Border>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Ck" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="CkScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CkScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Ck" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="CkScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="CkScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#20000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border x:Name="ProgressBarRoot" Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="0">
                            <Grid>
                                <Border x:Name="PART_Track" CornerRadius="4">
                                    <Border x:Name="PART_Indicator" Background="{DynamicResource AccentBrush}" CornerRadius="4" HorizontalAlignment="Left">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource AccentColor}" 
                                                              BlurRadius="{DynamicResource BloomBlurRadius}" 
                                                              ShadowDepth="0" 
                                                              Opacity="{DynamicResource BloomOpacity}"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Value" Value="0">
                                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="4" CornerRadius="2" Background="#44FFFFFF" Margin="0,8,0,0"/>
                            <Track x:Name="PART_Track" Grid.Row="0" Margin="0,8,0,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="{DynamicResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="16" Height="16" Fill="White"/>
                                                    <Ellipse Width="16" Height="16">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.5"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                            <TickBar x:Name="BottomTick" Grid.Row="1" Placement="Bottom" Fill="#88FFFFFF" Height="4" Visibility="Collapsed" Margin="0,4,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="TickPlacement" Value="BottomRight">
                                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Grid.ColumnSpan="2" Background="Transparent"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="4">
                                <Border Background="White" Opacity="0.05" CornerRadius="4"/>
                            </Border>
                            <ToggleButton Name="ToggleButton" Template="{DynamicResource ComboBoxToggleButton}" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" PlacementTarget="{Binding ElementName=ToggleButton}" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade" StaysOpen="False">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource PrimaryBrush}" BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{DynamicResource PrimaryBrush}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Border Background="White" Opacity="0.05" CornerRadius="4"/>
                                <ScrollViewer x:Name="PART_ContentHost"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <EventSetter Event="PreviewMouseMove" Handler="Btn_MouseTrack"/>
            <EventSetter Event="MouseLeave" Handler="Btn_MouseReset"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="GlowBorder" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Opacity="1">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="PlayGlow" 
                                                      Color="{DynamicResource AccentColor}" 
                                                      BlurRadius="{DynamicResource BloomBlurRadius}" 
                                                      ShadowDepth="0" 
                                                      Opacity="{DynamicResource BloomOpacity}"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="PlayBorder" 
                                    Background="Transparent" 
                                    CornerRadius="5" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="PlayContent" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform x:Name="BtnTr" X="0" Y="0"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PlayGlow" Storyboard.TargetProperty="BlurRadius" To="45" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="PlayGlow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PlayGlow" Storyboard.TargetProperty="BlurRadius" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="PlayGlow" Storyboard.TargetProperty="Opacity" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <core:ParticleBackground x:Name="ParticleBg"/>

        <Grid VerticalAlignment="Top" Height="40" Background="Transparent">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                <Image Source="{Binding Icon, ElementName=MainWnd}" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="BattleCraft Remake Launcher" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SystemButton}" Click="BtnMinimize_Click">
                    <Path Data="M0,8 L8,8 8,9 0,9 z" Width="10" Height="1" Stretch="Uniform" Fill="#AAAAAA" SnapsToDevicePixels="True"/>
                </Button>
                <Button Style="{StaticResource CloseButton}" Click="BtnClose_Click">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="#AAAAAA" StrokeThickness="1" Width="10" Height="10" Stretch="Uniform" SnapsToDevicePixels="True"/>
                </Button>
            </StackPanel>
        </Grid>

        <Separator VerticalAlignment="Top" Margin="0,40,0,0" Background="#444444" Opacity="0.5"/>


        <Grid x:Name="TitleContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-40,0,0" IsHitTestVisible="False" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="TitleEntranceTranslate" Y="30"/>
            </Grid.RenderTransform>
            <TextBlock x:Name="TitleText" Text="BATTLECRAFT REMAKE" 
                       FontSize="42" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="TitleTranslate" X="0" Y="0"/>
                </TextBlock.RenderTransform>
                <TextBlock.Effect>
                    <DropShadowEffect Color="{DynamicResource AccentColor}" 
                                      BlurRadius="{DynamicResource TitleBloomBlurRadius}" 
                                      ShadowDepth="0" 
                                      Opacity="{DynamicResource TitleBloomOpacity}"/>
                </TextBlock.Effect>
            </TextBlock>
        </Grid>

        <StackPanel x:Name="TopButtons" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,70,20,0">
            <Button x:Name="BtnReinstall" Content="Перекачать моды" Click="BtnReinstall_Click" Margin="0,0,10,0" Style="{StaticResource GlowButton}"/>
            <Button x:Name="BtnSettingsOpen" Content="Настройки" Click="BtnSettings_Click" Style="{StaticResource GlowButton}"/>
        </StackPanel>

        <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
            <TextBlock Text="Никнейм:" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
            <TextBox x:Name="UsernameBox"/>
            <Button Content="Войти" Margin="0,20,0,0" Height="45" Click="BtnLogin_Click" Style="{StaticResource GlowButton}"/>
        </StackPanel>

        <Grid x:Name="MainPanel" Visibility="Hidden">
            <TextBlock x:Name="WelcomeText" Text="Игрок" Foreground="#88FFFFFF" FontSize="13" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,70,0,0"/>
            <TextBlock x:Name="VersionText" Text="v2.0" Foreground="#55FFFFFF" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,90,0,0"/>
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="30,0,0,35">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPlay" Content="&#x25B6;  ИГРАТЬ" Click="BtnPlay_Click" Style="{StaticResource PlayButton}"/>
                    <CheckBox x:Name="DebugCheck" Content="Debug" Foreground="#88FFFFFF" Margin="15,0,0,0" VerticalAlignment="Center" Checked="DebugCheck_Changed" Unchecked="DebugCheck_Changed"/>
                    <CheckBox x:Name="ParticlesCheck" Content="Частицы" Foreground="#88FFFFFF" Margin="15,0,0,0" VerticalAlignment="Center" IsChecked="False" Checked="ParticlesCheck_Changed" Unchecked="ParticlesCheck_Changed"/>
                </StackPanel>
            </StackPanel>
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,35" Width="400">
                <TextBlock x:Name="StatusText" Text="Готов" Foreground="#AAFFFFFF" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar x:Name="GameProgressBar" Height="6" Background="#15FFFFFF" BorderThickness="0" Foreground="{DynamicResource AccentBrush}" Value="0" Style="{StaticResource GlowProgressBar}"/>
            </StackPanel>
        </Grid>

        <StackPanel x:Name="SetupPanel" Visibility="Hidden" VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
            <TextBlock Text="Никнейм:" Foreground="#CCFFFFFF" Margin="0,0,0,5"/>
            <TextBox x:Name="SetupUsernameBox"/>
            <TextBlock Text="Папка для Minecraft:" Foreground="#CCFFFFFF" Margin="0,15,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SetupPathBox" Grid.Column="0"/>
                <Button Content="..." Click="BtnSetupSelectFolder_Click" Grid.Column="1" Width="40" Margin="5,0,0,0" Style="{StaticResource GlowButton}"/>
            </Grid>
            <Button Content="Начать" Margin="0,25,0,0" Height="45" Click="BtnSetupComplete_Click" Style="{StaticResource PlayButton}"/>
        </StackPanel>


        <Grid x:Name="SettingsPanel" Background="#CC000000" Visibility="Hidden">
            <Border Background="Transparent" MouseDown="BtnCloseSettings_Click"/>
            <Border x:Name="SettingsBox" Background="{DynamicResource PrimaryBrush}" 
                    Width="500" MaxHeight="650" VerticalAlignment="Center" Margin="0,20,0,20"
                    CornerRadius="12" BorderBrush="#20FFFFFF" BorderThickness="1"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="SettingsScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="SettingsTranslate" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource AccentColor}" 
                                      BlurRadius="30" 
                                      ShadowDepth="0" 
                                      Opacity="{DynamicResource BloomOpacity}"/>
                </Border.Effect>
                <Grid>
                    <Border Background="Black" Opacity="0.2" CornerRadius="11"/>
                    <ScrollViewer x:Name="SettingsScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,10,0,10" PreviewMouseWheel="SettingsScroll_PreviewMouseWheel" ScrollChanged="SettingsScroll_ScrollChanged">
                        <StackPanel Margin="25">
                            <TextBlock x:Name="SettingsTitle" Text="НАСТРОЙКИ" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="SettingsTitleTranslate" Y="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentColor}" 
                                                      BlurRadius="{DynamicResource TitleBloomBlurRadius}" 
                                                      ShadowDepth="0" 
                                                      Opacity="{DynamicResource TitleBloomOpacity}"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <TextBlock Text="Внешний вид" HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,10"/>

                            <Button Click="BtnChangeIcon_Click" HorizontalAlignment="Center" Margin="0,0,0,15" Style="{StaticResource GlowButton}" ToolTip="Изменить иконку в панели задач и шапке">
                                <TextBlock Text="Сменить иконку лаунчера (ICO)" Margin="35,0"/>
                            </Button>

                            <TextBlock Text="Готовые пресеты:" Foreground="White" FontSize="13" Margin="0,10,0,5"/>


                            <ComboBox x:Name="ColorPresetCombo" SelectionChanged="ColorPreset_Changed" Height="40" VerticalContentAlignment="Center">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{Binding Tag}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Margin" Value="0,2,0,2"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="10,8" CornerRadius="4">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <Separator Background="{DynamicResource AccentBrush}" Margin="0,15" Opacity="0.3"/>

                            <TextBlock Text="Ручная настройка цветов:" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Основной (HEX):" Foreground="White" FontSize="12" Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="PrimaryColorBox" Width="100" Margin="0,0,5,0"/>
                                        <Button Content="OK" Click="BtnApplyPrimaryColor_Click" Width="40" Style="{StaticResource GlowButton}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Акцент (HEX):" Foreground="White" FontSize="12" Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="AccentColorBox" Width="100" Margin="0,0,5,0"/>
                                        <Button Content="OK" Click="BtnApplyAccentColor_Click" Width="40" Style="{StaticResource GlowButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="BloomEnabledCheck" Content="Включить свечение (Neon Glow)" IsChecked="True" Checked="BloomEnabledCheck_Changed" Unchecked="BloomEnabledCheck_Changed" Margin="0,5,0,5"/>

                            <TextBlock Text="Сила свечения:" Foreground="White" FontSize="12" Margin="0,5,0,2"/>
                            <Slider x:Name="BloomStrengthSlider" Minimum="0" Maximum="100" Value="60" ValueChanged="BloomStrengthSlider_ValueChanged"/>

                            <Separator Background="{DynamicResource AccentBrush}" Margin="0,15" Opacity="0.3"/>

                            <TextBlock Text="Система" Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,10"/>

                            <TextBlock Text="Выделенная память (RAM МБ):" Foreground="White" FontSize="13" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="RamSlider" Minimum="1024" Maximum="8192" Value="4096" VerticalAlignment="Center" Margin="0,0,15,0" LargeChange="1024" SmallChange="512" Ticks="2048,4096,6144,8192,12288,16384,24576,32768,49152,65536" TickPlacement="BottomRight" ValueChanged="RamSlider_ValueChanged"/>
                                <TextBox x:Name="RamBox" Text="{Binding Value, ElementName=RamSlider, UpdateSourceTrigger=PropertyChanged, Mode=OneWay, StringFormat={}{0:0}}" Grid.Column="1" TextAlignment="Center" IsReadOnly="True" Focusable="False" Cursor="Arrow"/>
                            </Grid>

                            <TextBlock Text="Путь к игре:" Foreground="White" FontSize="13" Margin="0,10,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PathBox" Grid.Column="0"/>
                                <Button Content="..." Click="BtnSelectFolder_Click" Grid.Column="1" Width="40" Margin="5,0,0,0" Style="{StaticResource GlowButton}"/>
                            </Grid>



                            <Button Content="СБРОСИТЬ ВСЕ НАСТРОЙКИ" Click="BtnResetAllSettings_Click" Margin="0,20,0,0" Background="#33FF0000" BorderBrush="Red" Foreground="Red" Style="{StaticResource GlowButton}"/>

                            <Button Content="Сохранить и Закрыть" Click="BtnSaveSettings_Click" Margin="0,15,0,0" Height="40" Style="{StaticResource GlowButton}" BorderBrush="Lime" Foreground="Lime"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        <Grid x:Name="CustomDialogOverlay" Visibility="Hidden" Background="#AA000000">
            <Border x:Name="CustomDialogBox" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource PrimaryBrush}" BorderThickness="1" BorderBrush="#33FFFFFF" CornerRadius="12" MinWidth="350" MaxWidth="500" Padding="25" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CustomDialogScale" ScaleX="0.9" ScaleY="0.9"/>
                        <TranslateTransform x:Name="CustomDialogTranslate" Y="20"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="CustomDialogTitle" Text="TITLE" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="CustomDialogMessage" Text="Message" FontSize="14" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" x:Name="CustomDialogButtons">
                        <Button x:Name="CustomDialogBtnCancel" Content="Отмена" Width="100" Margin="0,0,10,0" Style="{StaticResource GlowButton}" Click="CustomDialogCancel_Click"/>
                        <Button x:Name="CustomDialogBtnOk" Content="OK" Width="100" Style="{StaticResource GlowButton}" Click="CustomDialogOk_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
